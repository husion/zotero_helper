{
  "manifest_version": 3,
  "name": "Zotero WebDAV Downloader",
  "version": "1.1.0",
  "description": "Download Zotero web attachments directly from your WebDAV storage.",
  "permissions": [
    "storage",
    "downloads"
  ],
  "host_permissions": [
    "https://www.zotero.org/*",
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Zotero WebDAV Downloader",
    "default_icon": {
      "16": "src/icons/icon16.png",
      "32": "src/icons/icon32.png",
      "48": "src/icons/icon48.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.zotero.org/*"
      ],
      "js": [
        "src/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "src/options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "src/icons/icon16.png",
    "32": "src/icons/icon32.png",
    "48": "src/icons/icon48.png",
    "128": "src/icons/icon128.png"
  }
}
